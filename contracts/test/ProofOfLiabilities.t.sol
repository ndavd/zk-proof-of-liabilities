pragma solidity ^0.8.13;

import {Test} from "forge-std/Test.sol";
import {ProofOfLiabilities, IVerifier} from "../src/ProofOfLiabilities.sol";
import {HonkVerifier} from "../src/Verifier.sol";

contract ProofOfLiabilitiesTest is Test {
    ProofOfLiabilities public pol;
    HonkVerifier public verifier;

    address owner = makeAddr("owner");

    bytes32 constant ROOT_HASH = 0x2435ee3269bda147ae3f77afec5380a3bf7150139f6e179b81900cdc439e7436;
    uint128 constant ROOT_BALANCE = 397559;
    bytes32 constant USER_HASH = 0x2abca1526ee7d8fb15d69e4a889dfc8677fc5900e2bfdab802c9722f782ac77a;

    // TODO: generate via ffi
    bytes constant PROOF =
        hex"";

    function setUp() public {
        verifier = new HonkVerifier();
        pol = new ProofOfLiabilities(owner, IVerifier(address(verifier)));

        vm.prank(owner);
        pol.addSnapshot(ROOT_HASH, ROOT_BALANCE);
    }

    function test_verifyCurrentSnapshot() public view {
        bool verified = pol.verifyCurrentSnapshot(PROOF, USER_HASH);
        assertTrue(verified);
    }

    function test_verifySnapshot() public view {
        bool verified = pol.verifySnapshot(1, PROOF, USER_HASH);
        assertTrue(verified);
    }

    function test_verifyCurrentSnapshot_RevertsOnWrongUserHash() public view {
        bool verified = pol.verifyCurrentSnapshot(PROOF, keccak256("bad"));
        assertFalse(verified);
    }

    function test_verifySnapshot_RevertsIfSnapshotDoesNotExist() public {
        vm.expectRevert(ProofOfLiabilities.ProofOfLiabilities__SnapshotDoesNotExist.selector);
        pol.verifySnapshot(0, PROOF, USER_HASH);
        vm.expectRevert(ProofOfLiabilities.ProofOfLiabilities__SnapshotDoesNotExist.selector);
        pol.verifySnapshot(2, PROOF, USER_HASH);
    }

    function test_addSnapshot_RevertsIfNotOwner() public {
        vm.expectRevert();
        pol.addSnapshot(ROOT_HASH, ROOT_BALANCE);
    }

    function test_addSnapshotEmitsEvent() public {
        vm.expectEmit(true, true, true, true);
        emit ProofOfLiabilities.ProofOfLiabilities__NewSnapshot(2, ROOT_HASH, ROOT_BALANCE, block.timestamp);
        vm.prank(owner);
        pol.addSnapshot(ROOT_HASH, ROOT_BALANCE);
    }
}
